# ==========================================
# v8: SimVP（纯 2D CNN + 帧堆叠，CVPR'22 SimVP paper 风格）
# 主张：video prediction 不一定需要 recurrent/attention，纯 CNN 也行
# 适合验证"复杂时序模块到底有没有用"
# ==========================================

class _ResBlock(nn.Module):
    """标准 2-conv residual block：Conv-GN-GELU-Conv-GN，残差相加。"""
    def __init__(self, channels):
        super().__init__()
        self.body = nn.Sequential(
            nn.Conv2d(channels, channels, 3, padding=1),
            nn.GroupNorm(min(8, channels), channels),
            nn.GELU(),
            nn.Conv2d(channels, channels, 3, padding=1),
            nn.GroupNorm(min(8, channels), channels),
        )
        self.act = nn.GELU()

    def forward(self, x):
        return self.act(x + self.body(x))


@export
class PedPred_v8_simvp(nn.Module):
    """SimVP-style：5 帧堆叠成 20 通道输入 → 纯 2D CNN → 1 帧输出。

    架构：
      1. Input: [B, T=5, 4, 36, 12] → reshape → [B, 20, 36, 12]
      2. Encoder: Conv → ResBlock × N_enc，3 个尺度（36×12, 18×6, 9×3）
      3. Hidden: ResBlock × N_hid 在最深层
      4. Decoder: ConvT 上采样 + skip + ResBlock，对称结构
      5. Output: 1×1 Conv → [B, 4, 36, 12]

    特点：
      - 完全没有循环 / attention：训练最稳定，最快
      - 测试"5 帧时序信息是否需要复杂模块"
      - 参数 ~3M（channels=64, n_enc=2, n_hid=4）
    """
    def __init__(self, channels: int = 64, n_enc: int = 2, n_hid: int = 4):
        super().__init__()
        T, C = 5, 4
        in_ch = T * C  # 20

        # ====== 输入投影 ======
        self.input_proj = nn.Conv2d(in_ch, channels, 3, padding=1)

        # ====== Encoder：2 个下采样阶段 ======
        # 阶段 0: 36×12, channels
        self.enc0 = nn.Sequential(*[_ResBlock(channels) for _ in range(n_enc)])
        # 阶段 1: 18×6, 2*channels
        self.down1 = nn.Conv2d(channels, channels * 2, 3, stride=2, padding=1)
        self.enc1 = nn.Sequential(*[_ResBlock(channels * 2) for _ in range(n_enc)])
        # 阶段 2: 9×3, 4*channels
        self.down2 = nn.Conv2d(channels * 2, channels * 4, 3, stride=2, padding=1)
        self.enc2 = nn.Sequential(*[_ResBlock(channels * 4) for _ in range(n_enc)])

        # ====== Hidden（最深层做 N_hid 个 ResBlock）======
        self.hidden = nn.Sequential(*[_ResBlock(channels * 4) for _ in range(n_hid)])

        # ====== Decoder：对称上采样 ======
        self.up1 = nn.ConvTranspose2d(channels * 4, channels * 2, 4, stride=2, padding=1)
        self.dec1 = nn.Sequential(
            nn.Conv2d(channels * 4, channels * 2, 1),  # 拼 skip → 减半
            *[_ResBlock(channels * 2) for _ in range(n_enc)]
        )
        self.up2 = nn.ConvTranspose2d(channels * 2, channels, 4, stride=2, padding=1)
        self.dec2 = nn.Sequential(
            nn.Conv2d(channels * 2, channels, 1),
            *[_ResBlock(channels) for _ in range(n_enc)]
        )

        # ====== 输出 ======
        self.out_conv = nn.Conv2d(channels, C, 1)

    def forward(self, input, hidden=None, *, horizon=None):
        # input: GridData 或 [B, T, 4, H, W]
        input = GridData(input).as_tensor('density', 'vel_mean', 'vel_var')
        B, T, C, H, W = input.shape
        # 5 帧堆叠成通道
        x = input.reshape(B, T * C, H, W)  # [B, 20, 36, 12]

        # Encode
        x = self.input_proj(x)             # [B, ch, 36, 12]
        e0 = self.enc0(x)                  # [B, ch, 36, 12]
        e1 = self.enc1(self.down1(e0))     # [B, 2ch, 18, 6]
        e2 = self.enc2(self.down2(e1))     # [B, 4ch, 9, 3]

        # Hidden
        h = self.hidden(e2)                # [B, 4ch, 9, 3]

        # Decode + skip
        d1 = self.up1(h)                              # [B, 2ch, 18, 6]
        d1 = self.dec1(torch.cat([d1, e1], dim=1))    # [B, 2ch, 18, 6]
        d2 = self.up2(d1)                             # [B, ch, 36, 12]
        d2 = self.dec2(torch.cat([d2, e0], dim=1))    # [B, ch, 36, 12]

        out = self.out_conv(d2)            # [B, 4, 36, 12]

        # Clamp + GridData wrap
        logdensity = torch.clamp(out[:, 0:1], min=-20.0, max=10.0)
        vel_mean = torch.clamp(out[:, 1:3], min=-15.0, max=15.0)
        vel_logvar = torch.clamp(out[:, 3:4], min=-20.0, max=5.0)

        ld = logdensity.unsqueeze(1)
        vm = vel_mean.unsqueeze(1)
        vlv = vel_logvar.unsqueeze(1)
        return GridData(logdensity=ld, vel_mean=vm, vel_logvar=vlv)


PedPred3_simvp = PedPred_v8_simvp


# ==========================================
# v9: ConvNeXt-style 视频预测（现代 conv block）
# 帧堆叠 → ConvNeXt blocks（depthwise + LayerNorm + GELU + 1x1）
# ==========================================

class _ConvNeXtBlock(nn.Module):
    """ConvNeXt block: 7x7 depthwise → LayerNorm → 1x1 → GELU → 1x1，残差。"""
    def __init__(self, dim, mlp_ratio=4):
        super().__init__()
        self.dwconv = nn.Conv2d(dim, dim, 7, padding=3, groups=dim)
        self.norm = nn.LayerNorm(dim, eps=1e-6)  # 在 channel 最后维做
        self.pwconv1 = nn.Linear(dim, mlp_ratio * dim)
        self.act = nn.GELU()
        self.pwconv2 = nn.Linear(mlp_ratio * dim, dim)

    def forward(self, x):
        # x: [B, C, H, W]
        residual = x
        x = self.dwconv(x)
        x = x.permute(0, 2, 3, 1)  # [B, H, W, C]
        x = self.norm(x)
        x = self.pwconv1(x)
        x = self.act(x)
        x = self.pwconv2(x)
        x = x.permute(0, 3, 1, 2)  # [B, C, H, W]
        return residual + x


@export
class PedPred_v9_convnext(nn.Module):
    """ConvNeXt-style 视频预测：5 帧堆叠 → ConvNeXt → 1 帧输出。

    比 SimVP 用更现代的 block（depthwise + LN + GELU），
    研究表明 ConvNeXt 能在不少任务上匹配/超过 transformer。
    """
    def __init__(self, dim: int = 96, n_blocks: int = 8):
        super().__init__()
        T, C = 5, 4
        in_ch = T * C  # 20
        self.input_proj = nn.Conv2d(in_ch, dim, 3, padding=1)
        self.blocks = nn.Sequential(*[_ConvNeXtBlock(dim) for _ in range(n_blocks)])
        self.norm = nn.LayerNorm(dim)
        self.out_conv = nn.Conv2d(dim, C, 1)

    def forward(self, input, hidden=None, *, horizon=None):
        input = GridData(input).as_tensor('density', 'vel_mean', 'vel_var')
        B, T, C, H, W = input.shape
        x = input.reshape(B, T * C, H, W)  # [B, 20, 36, 12]
        x = self.input_proj(x)              # [B, dim, 36, 12]
        x = self.blocks(x)                  # [B, dim, 36, 12]
        # LayerNorm in channel-last
        x = x.permute(0, 2, 3, 1)
        x = self.norm(x)
        x = x.permute(0, 3, 1, 2)
        out = self.out_conv(x)              # [B, 4, 36, 12]
        logdensity = torch.clamp(out[:, 0:1], min=-20.0, max=10.0)
        vel_mean = torch.clamp(out[:, 1:3], min=-15.0, max=15.0)
        vel_logvar = torch.clamp(out[:, 3:4], min=-20.0, max=5.0)
        ld = logdensity.unsqueeze(1)
        vm = vel_mean.unsqueeze(1)
        vlv = vel_logvar.unsqueeze(1)
        return GridData(logdensity=ld, vel_mean=vm, vel_logvar=vlv)


PedPred3_convnext = PedPred_v9_convnext


# ==========================================
# v10: PedPred_v4 with GRU instead of STLSTM
# 最小改动，保留 PedPred_v4 整体结构（3 层 RNN encoder + decoder + temporal attn），
# 只是把 Conv2dSTLSTM (5 个门) 换成 Conv2dGRU (3 个门)
# 目的：测试 STLSTM 5 个门是不是不稳定的来源
# ==========================================

@export
class PedPred_v10_grustack(EncoderForecaster):
    """PedPred_v4 完全相同结构，但用 ``Conv2dGRU`` 代替 ``Conv2dSTLSTM``。"""
    def __init__(self, *args, **kwargs):
        C = 1 + 2 + 1   # logdensity(1) + vel_mean(2) + vel_logvar(1)

        # GRU 用同样的 in/hidden kernel
        rnn_kwargs = dict(in_kernel_size=3, hidden_kernel_size=5, activation=LeakyReLU(0.2))

        hid0, hid1, hid2 = 16, 32, 128

        encoder = Encoder(
            Conv2d(C, prev := 16, kernel_size=3, stride=1, padding=1), LeakyReLU(0.2),
            Conv2dGRU(prev, prev := hid0, **rnn_kwargs),
            Conv2d(prev, prev := 32, kernel_size=3, stride=2, padding=1), LeakyReLU(0.2),
            Conv2dGRU(prev, prev := hid1, **rnn_kwargs),
            Conv2d(prev, prev := 64, kernel_size=3, stride=2, padding=1), LeakyReLU(0.2),
            Conv2dGRU(prev, prev := hid2, **rnn_kwargs),
        )

        forecaster = Forecaster(
            Conv2dGRU(None, prev := hid2, **rnn_kwargs),
            ConvTranspose2d(prev, prev := 32, kernel_size=4, stride=2, padding=1), LeakyReLU(0.2),
            Conv2dGRU(prev, prev := hid1, **rnn_kwargs),
            ConvTranspose2d(prev, prev := 16, kernel_size=4, stride=2, padding=1), LeakyReLU(0.2),
            Conv2dGRU(prev, prev := hid0, **rnn_kwargs),
            ConvTranspose2d(prev, prev := 16, kernel_size=3, stride=1, padding=1), LeakyReLU(0.2),
            Conv2d(prev, prev := 16, kernel_size=3, stride=1, padding=1), LeakyReLU(0.2),
            Conv2d(prev, C, kernel_size=1),
        )

        super().__init__(
            encoder, forecaster, *args,
            skip_channels=[hid0, hid1, hid2],
            use_temporal_attn=True,
            **kwargs
        )

    def forward(self, input, hidden=None, *, horizon=None):
        input = GridData(input).as_tensor('density', 'vel_mean', 'vel_var')
        input = input.transpose(0, 1)
        output = super().forward(input, hidden, horizon=horizon)
        logdensity, vel_mean, vel_logvar = output.split((1, 2, 1), dim=-3)
        logdensity = torch.clamp(logdensity, min=-20.0, max=10.0)
        vel_mean   = torch.clamp(vel_mean,   min=-15.0, max=15.0)
        vel_logvar = torch.clamp(vel_logvar, min=-20.0, max=5.0)
        output = GridData(logdensity=logdensity, vel_mean=vel_mean, vel_logvar=vel_logvar)
        output = GridData(output.transpose(1, 0))
        return output


