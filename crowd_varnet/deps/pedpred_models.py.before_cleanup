# ==========================================
# v7: Earthformer-lite（patch embed + axial space-time attention）
# 灵感：NeurIPS'22 Earthformer / TimeSformer 因式化 attention
# 适合小 grid (36×12) + 短时序 (T=5) 的 video prediction
# ==========================================

class _SinCosPosEmbedND(nn.Module):
    """N-D 可学习位置编码（spatial + temporal 各一份）。"""
    def __init__(self, n_spatial: int, n_temporal: int, dim: int):
        super().__init__()
        self.spatial_pe = nn.Parameter(torch.zeros(1, n_spatial, dim))
        self.temporal_pe = nn.Parameter(torch.zeros(1, n_temporal, dim))
        nn.init.trunc_normal_(self.spatial_pe, std=0.02)
        nn.init.trunc_normal_(self.temporal_pe, std=0.02)


class _MHSA(nn.Module):
    """简洁的 Multi-Head Self-Attention（含残差 + LayerNorm + FFN）。"""
    def __init__(self, dim: int, n_heads: int = 4, mlp_ratio: float = 4.0, dropout: float = 0.0):
        super().__init__()
        self.norm1 = nn.LayerNorm(dim)
        self.attn = nn.MultiheadAttention(dim, n_heads, dropout=dropout, batch_first=True)
        self.norm2 = nn.LayerNorm(dim)
        hidden = int(dim * mlp_ratio)
        self.mlp = nn.Sequential(
            nn.Linear(dim, hidden), nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(hidden, dim),
            nn.Dropout(dropout),
        )
    def forward(self, x):  # x: [B, N, D]
        h = self.norm1(x)
        a, _ = self.attn(h, h, h, need_weights=False)
        x = x + a
        x = x + self.mlp(self.norm2(x))
        return x


class _AxialBlock(nn.Module):
    """因式化 space-time attention block（TimeSformer 风格）。

    输入 x: [B, T, S, D]（S = 空间 patch 数）
    1. 空间 attention: 对每帧内 S 个 patch 做 self-attention
    2. 时序 attention: 对每个空间位置上 T 个时间步做 self-attention
    """
    def __init__(self, dim: int, n_heads: int = 4):
        super().__init__()
        self.spatial_attn = _MHSA(dim, n_heads)
        self.temporal_attn = _MHSA(dim, n_heads)

    def forward(self, x):
        # x: [B, T, S, D]
        B, T, S, D = x.shape
        # 1) Spatial: reshape to [B*T, S, D]
        x_s = x.reshape(B * T, S, D)
        x_s = self.spatial_attn(x_s)
        x = x_s.reshape(B, T, S, D)
        # 2) Temporal: reshape to [B*S, T, D]
        x_t = x.permute(0, 2, 1, 3).reshape(B * S, T, D)
        x_t = self.temporal_attn(x_t)
        x = x_t.reshape(B, S, T, D).permute(0, 2, 1, 3)
        return x


@export
class PedPred_v7_earthformer(nn.Module):
    """Earthformer-lite for ATC corridor.

    架构：
      1. **Patch embed**：2×2 spatial conv stride 2 → token grid 18×6 = 108 个空间 token / 帧
      2. **位置编码**：spatial 108 + temporal 5
      3. **N 个 axial transformer blocks**：每个 block 先空间 attention 再时序 attention
      4. **Patch unembed**：转置卷积 ↑2 → 36×12，输出 4 通道

    参数量约 2-3M（embed_dim=128, 4 blocks）。
    优点：
      - 全局 attention 可建模 corridor 两端交互
      - LayerNorm + GELU + 残差连接：训练极稳定
      - 跟 PedPred_v4 接口一致
    """
    def __init__(self, embed_dim: int = 128, n_blocks: int = 4, n_heads: int = 4):
        super().__init__()
        self.embed_dim = embed_dim
        self.in_ch = 4   # density + vel_mean(2) + vel_var
        # ====== Patch embed: 2×2 spatial conv stride 2 ======
        self.patch_embed = nn.Conv2d(self.in_ch, embed_dim, kernel_size=2, stride=2)
        # 36×12 → 18×6, S = 18*6 = 108
        # ====== 位置编码 ======
        self.pos_embed = _SinCosPosEmbedND(n_spatial=18 * 6, n_temporal=5, dim=embed_dim)
        # ====== Transformer blocks ======
        self.blocks = nn.ModuleList([
            _AxialBlock(embed_dim, n_heads) for _ in range(n_blocks)
        ])
        self.norm = nn.LayerNorm(embed_dim)
        # ====== 输出头：last frame 的 token → patch unembed ======
        # 用 ConvTranspose2d 上采样回 36×12
        self.head = nn.ConvTranspose2d(embed_dim, self.in_ch, kernel_size=2, stride=2)

    def forward(self, input, hidden=None, *, horizon=None):
        # input: GridData 或 [B, T, 4, H, W]
        input = GridData(input).as_tensor('density', 'vel_mean', 'vel_var')
        B, T, C, H, W = input.shape
        assert (H, W) == (36, 12), f"v7 expects 36×12 grid, got {H}×{W}"
        assert T == 5, f"v7 expects T=5, got T={T}"

        # 1) Patch embed per frame: [B*T, 4, 36, 12] → [B*T, D, 18, 6]
        x = input.reshape(B * T, C, H, W)
        x = self.patch_embed(x)  # [B*T, D, 18, 6]
        D = x.shape[1]
        Ht, Wt = x.shape[2], x.shape[3]
        # Reshape to [B, T, S, D] where S = Ht*Wt = 108
        x = x.flatten(2).permute(0, 2, 1)        # [B*T, S, D]
        x = x.reshape(B, T, Ht * Wt, D)          # [B, T, S, D]

        # 2) 位置编码（broadcast）
        x = x + self.pos_embed.spatial_pe.unsqueeze(1)   # spatial: [1, 1, S, D]
        x = x + self.pos_embed.temporal_pe.unsqueeze(2)  # temporal: [1, T, 1, D]

        # 3) Axial transformer blocks
        for blk in self.blocks:
            x = blk(x)
        x = self.norm(x)  # [B, T, S, D]

        # 4) 取 last frame 的 token 做预测
        x_last = x[:, -1]                           # [B, S, D]
        x_last = x_last.permute(0, 2, 1).reshape(B, D, Ht, Wt)  # [B, D, 18, 6]

        # 5) Unembed (ConvTranspose 2x2 stride 2) → [B, 4, 36, 12]
        out = self.head(x_last)

        # 6) 拆分 + clamp（同 PedPred_v4）
        logdensity = torch.clamp(out[:, 0:1], min=-20.0, max=10.0)
        vel_mean = torch.clamp(out[:, 1:3], min=-15.0, max=15.0)
        vel_logvar = torch.clamp(out[:, 3:4], min=-20.0, max=5.0)

        ld = logdensity.unsqueeze(1)
        vm = vel_mean.unsqueeze(1)
        vlv = vel_logvar.unsqueeze(1)
        return GridData(logdensity=ld, vel_mean=vm, vel_logvar=vlv)


