        x = input_t.transpose(0, 1)
        output = super(PedPred_v11_grustack_mid, self).forward(x, hidden, horizon=horizon)
        logdensity, vel_mean, vel_logvar = output.split((1, 2, 1), dim=-3)

        vel_mean = vel_mean.transpose(0, 1)  # [B, horizon, 2, H, W]
        if vel_mean.shape[1] == last_vel.shape[1]:
            vel_mean = vel_mean + last_vel
        else:
            vel_mean = vel_mean + last_vel.expand_as(vel_mean)
        vel_mean = vel_mean.transpose(0, 1)

        logdensity = torch.clamp(logdensity, min=-20.0, max=10.0)
        vel_mean   = torch.clamp(vel_mean,   min=-15.0, max=15.0)
