# ==========================================
# v6: U-Net 编码/解码 + ConvLSTM 瓶颈（更简单更稳定）
# ==========================================

class _UnetConvBlock(nn.Module):
    """两层 Conv3x3 + GroupNorm + GELU。"""
    def __init__(self, in_ch, out_ch, mid_ch=None):
        super().__init__()
        m = mid_ch if mid_ch is not None else out_ch
        self.body = nn.Sequential(
            nn.Conv2d(in_ch, m, 3, padding=1),
            nn.GroupNorm(num_groups=min(8, m), num_channels=m),
            nn.GELU(),
            nn.Conv2d(m, out_ch, 3, padding=1),
            nn.GroupNorm(num_groups=min(8, out_ch), num_channels=out_ch),
            nn.GELU(),
        )
    def forward(self, x):
        return self.body(x)


class _SimpleConvLSTM(nn.Module):
    """标准 ConvLSTM 单元（i, f, g, o gates）。比 STLSTM 简单，比 GRU 多记忆通道。"""
    def __init__(self, in_ch, hidden_ch, kernel=3):
        super().__init__()
        self.hidden_ch = hidden_ch
        pad = kernel // 2
        # x_t 和 h_{t-1} 拼接后，用一个 conv 算出 4 个 gate
        self.conv = nn.Conv2d(in_ch + hidden_ch, 4 * hidden_ch, kernel, padding=pad)

    def forward(self, x_seq):
        # x_seq: [B, T, C_in, H, W]
        B, T, _, H, W = x_seq.shape
        h = torch.zeros(B, self.hidden_ch, H, W, device=x_seq.device, dtype=x_seq.dtype)
        c = torch.zeros(B, self.hidden_ch, H, W, device=x_seq.device, dtype=x_seq.dtype)
        for t in range(T):
            x_t = x_seq[:, t]
            gates = self.conv(torch.cat([x_t, h], dim=1))
            i, f, g, o = gates.chunk(4, dim=1)
            i = torch.sigmoid(i)
            f = torch.sigmoid(f)
            o = torch.sigmoid(o)
            g = torch.tanh(g)
            c = f * c + i * g
            h = o * torch.tanh(c)
        return h  # 返回最后一步的 hidden state [B, hidden_ch, H, W]


@export
class PedPred_v6_unet(nn.Module):
    """U-Net + ConvLSTM 瓶颈架构教师。

    设计思路：
      1. **逐帧 U-Net 编码**：5 个输入帧共享 encoder，每帧独立产出 multi-scale 特征
      2. **ConvLSTM 在瓶颈处**：仅在最深层（9×3）做时序融合，避免 STLSTM 多层不稳定
      3. **U-Net 解码 + skip from last frame**：解码时与 last input frame 的 encoder feature 做 skip
      4. **直接输出 4 通道**：(logdensity, vel_x, vel_y, vel_logvar)，跟 PedPred_v4 兼容

    参数量约 4M（vs PedPred_v4 7M, PedPred_v4_wide 28M）。
    GroupNorm + GELU 比 LeakyReLU + STLSTM 更稳定，无 tanh 累积爆炸点。
    """
    def __init__(self):
        super().__init__()
        # 输入 4 通道 (density, vel_mean[2], vel_var)
        # ====== Encoder（per-frame, 共享）======
        self.enc0 = _UnetConvBlock(4, 32)              # 36×12, 32ch
        self.down1 = nn.Conv2d(32, 64, 3, stride=2, padding=1)  # → 18×6
        self.enc1 = _UnetConvBlock(64, 64)             # 18×6, 64ch
        self.down2 = nn.Conv2d(64, 128, 3, stride=2, padding=1) # → 9×3
        self.enc2 = _UnetConvBlock(128, 128)           # 9×3, 128ch

        # ====== ConvLSTM 瓶颈 ======
        self.lstm = _SimpleConvLSTM(in_ch=128, hidden_ch=192, kernel=3)

        # ====== Decoder ======
        # 上采样 + 与 last frame 的 encoder skip 拼接
        self.up1 = nn.ConvTranspose2d(192, 64, 4, stride=2, padding=1)  # 9×3 → 18×6
        self.dec1 = _UnetConvBlock(64 + 64, 64)        # 拼 skip from enc1[last]
        self.up2 = nn.ConvTranspose2d(64, 32, 4, stride=2, padding=1)   # 18×6 → 36×12
        self.dec2 = _UnetConvBlock(32 + 32, 32)        # 拼 skip from enc0[last]
        self.out_conv = nn.Conv2d(32, 4, 1)

    def forward(self, input, hidden=None, *, horizon=None):
        # input: [B, T, 4, H, W] 或 GridData 包装
        input = GridData(input).as_tensor('density', 'vel_mean', 'vel_var')
        B, T, C, H, W = input.shape
        x = input.reshape(B * T, C, H, W)

        # Per-frame encoding
        e0 = self.enc0(x)                      # [BT, 32, 36, 12]
        e1 = self.enc1(self.down1(e0))         # [BT, 64, 18, 6]
        e2 = self.enc2(self.down2(e1))         # [BT, 128, 9, 3]

        # Reshape e2 back to [B, T, C, H, W] for ConvLSTM
        _, C2, H2, W2 = e2.shape
        e2_seq = e2.reshape(B, T, C2, H2, W2)

        # ConvLSTM bottleneck → [B, 192, 9, 3]
        h = self.lstm(e2_seq)

        # Last-frame skip features
        e0_last = e0.reshape(B, T, 32, H, W)[:, -1]    # [B, 32, 36, 12]
        e1_last = e1.reshape(B, T, 64, 18, 6)[:, -1]   # [B, 64, 18, 6]

        # Decoder
        d1 = self.up1(h)                                # [B, 64, 18, 6]
        d1 = self.dec1(torch.cat([d1, e1_last], dim=1)) # [B, 64, 18, 6]
        d2 = self.up2(d1)                               # [B, 32, 36, 12]
        d2 = self.dec2(torch.cat([d2, e0_last], dim=1)) # [B, 32, 36, 12]
        out = self.out_conv(d2)                         # [B, 4, 36, 12]

        # 拆分 + 物理 clamp（跟 PedPred_v4 一致）
        logdensity = torch.clamp(out[:, 0:1], min=-20.0, max=10.0)  # [B, 1, H, W]
        vel_mean = torch.clamp(out[:, 1:3], min=-15.0, max=15.0)    # [B, 2, H, W]
        vel_logvar = torch.clamp(out[:, 3:4], min=-20.0, max=5.0)   # [B, 1, H, W]

        # 加 horizon=1 维：[B, 1, C, H, W]
        ld = logdensity.unsqueeze(1)
        vm = vel_mean.unsqueeze(1)
        vlv = vel_logvar.unsqueeze(1)
        return GridData(logdensity=ld, vel_mean=vm, vel_logvar=vlv)


